# --- Dependencies ---
node_modules/
jspm_packages/
web_modules/

# --- Build Output (compiled binaries and installers must not be committed) ---
dist/
build/
out/
.next/
.nuxt/
.vuepress/dist

# --- Environment Variables (critical for security) ---
.env
.env.*
!.env.example

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# --- Runtime Data & User Data (keep personal data out of the repo) ---
pids
*.pid
*.seed
*.pid.lock
snapshots.json

# --- Testing & Coverage ---
coverage
*.lcov
.nyc_output
lib-cov

# --- IDE & Editor Configs (keep personal settings out of the repo) ---
.vscode/
.idea/
*.swp
*.swo

# --- Operating System Files (macOS and Windows junk files) ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- Optional Caches ---
.npm
.eslintcache
.stylelintcache
.cache
.parcel-cache
# --- Personal Obsidian vault (local notes, not part of the app) ---
Context-Bot-Vault/
